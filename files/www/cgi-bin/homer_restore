#!/usr/bin/lua

-- Flush output helper
local function send_output(s)
    io.stdout:write(s)
    io.stdout:flush()
end

local function die(msg, status)
    status = status or 500
    local text = status == 400 and "Bad Request" or "Internal Server Error"
    send_output("Status: " .. status .. " " .. text .. "\r\n")
    send_output("Content-Type: text/html\r\n")
    send_output("\r\n")
    send_output("<h1>Error</h1><p>" .. msg .. "</p>")
    send_output('<p><a href="/cgi-bin/luci/admin/services/homer">Go back</a></p>')
    os.exit(1)
end

if (os.getenv("REQUEST_METHOD") or "GET") ~= "POST" then
    die("Only POST allowed", 405)
end

local clen = tonumber(os.getenv("CONTENT_LENGTH") or "0")
if clen <= 0 then
    die("Empty POST body", 400)
end

-- Read exactly clen bytes from stdin
local raw = io.stdin:read(clen)
if not raw or #raw == 0 then
    die("Failed to read POST body", 400)
end

-- Debug: save raw for inspection
local dbg = io.open("/tmp/homer_raw.bin", "w")
dbg:write("LEN=" .. #raw .. "\n")
dbg:write(raw:sub(1, 200):gsub("[^%w%p%s]", ".") .. "\n")
dbg:close()

-- Find boundary
local ctype = os.getenv("CONTENT_TYPE") or ""
local boundary = ctype:match("boundary=(.+)")
if not boundary then
    die("Missing boundary in Content-Type", 400)
end

-- Find file field
local field_pos = raw:find('name="restore_file"', 1, true)
if not field_pos then
    field_pos = raw:find('name="archive"', 1, true)
end

if not field_pos then
    die("File field not found. Expected 'restore_file' or 'archive'.", 400)
end

-- Find end of headers (empty line)
local header_end = raw:find("\r\n\r\n", field_pos, true)
if not header_end then
    die("Malformed multipart: no empty line after headers", 400)
end

local file_start = header_end + 4

-- Find closing boundary
local close1 = "\r\n--" .. boundary .. "--"
local close2 = "\r\n--" .. boundary .. "\r\n"

local file_end = raw:find(close1, file_start, true)
if not file_end then
    file_end = raw:find(close2, file_start, true)
end

if not file_end then
    die("Cannot find closing boundary", 500)
end

-- Extract file content
local file_content = raw:sub(file_start, file_end - 1)

-- Trim trailing \r\n
while file_content:sub(-1) == "\r" or file_content:sub(-1) == "\n" do
    file_content = file_content:sub(1, -2)
end

if #file_content == 0 then
    die("File content is empty", 400)
end

-- Check ZIP magic
local magic = file_content:sub(1, 4)
if magic ~= "PK\03\04" then
    local hex = ""
    for i = 1, 4 do
        hex = hex .. string.format("%02X ", magic:byte(i) or 0)
    end
    die("Not a valid zip (magic: " .. hex .. ")", 400)
end

-- Save to temp file
local tmp_path = "/tmp/homer_upload_" .. os.time() .. ".zip"
local f = io.open(tmp_path, "wb")
if not f then die("Cannot create temp file", 500) end
f:write(file_content)
f:close()

-- Backup
os.execute('rm -rf /www/homer_bak 2>/dev/null')
os.execute('[ -d /www/homer ] && mv /www/homer /www/homer_bak')

-- Extract using 7z
os.execute('mkdir -p /www/homer')
local ok, exit_code, status_code = os.execute('cd /www/homer && 7z x "' .. tmp_path .. '" -y >/dev/null 2>&1')

-- Handle os.execute return values (Lua 5.1: returns true/false/nil, exit_code)
local code = 0
if type(ok) == "number" then
    code = ok       -- Lua 5.2+ style
elseif type(exit_code) == "number" then
    code = exit_code
elseif ok then
    code = 0
else
    code = 1
end

if code ~= 0 then
    os.execute('rm -rf /www/homer')
    os.execute('[ -d /www/homer_bak ] && mv /www/homer_bak /www/homer')
    os.remove(tmp_path)
    die("Failed to extract zip (code: " .. code .. ")", 500)
end

os.remove(tmp_path)
os.execute('rm -rf /www/homer_bak 2>/dev/null')
os.execute('chmod -R 755 /www/homer')

-- Success: redirect
send_output("Status: 302 Found\r\n")
send_output("Location: /cgi-bin/luci/admin/services/homer\r\n")
send_output("Content-Type: text/html\r\n")
send_output("\r\n")
send_output('<html><head><meta http-equiv="refresh" content="0;url=/cgi-bin/luci/admin/services/homer"></head><body><script>window.location="/cgi-bin/luci/admin/services/homer"</script></body></html>')
